# Frontend runtime
VITE_API_BASE_URL=http://127.0.0.1:5000/api
VITE_SOCKET_URL=http://127.0.0.1:5000

# Backend runtime (server/src)
PORT=5000
FRONTEND_PORT=8088
NODE_ENV=development
CORS_ORIGINS=http://localhost:8088,http://127.0.0.1:8088

# MariaDB for users/reports
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=root
DB_PASSWORD=123456
DB_NAME=abc_social

# MongoDB for posts/comments/messages mirror
MONGO_URI=mongodb://127.0.0.1:27017/abc_social
MONGO_DB_NAME=abc_social

# JWT
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Auth OTP behavior
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_EXPOSE_DEBUG_CODES=true

# Optional AWS
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
